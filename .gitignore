# Root-level combined .gitignore for backend and frontend

# Node / JavaScript
/node_modules
/frontend/node_modules
/npm-debug.log*
/yarn-debug.log*
/yarn-error.log*
/pnpm-debug.log*

# Next.js / frontend build
/.next
/frontend/.next
/out
/frontend/out
/build
/frontend/build
/.vercel
/frontend/.vercel
/.turbo
/frontend/.turbo
next-env.d.ts
/frontend/next-env.d.ts

# Environment files
.env
.env.*

# macOS
.DS_Store

# SSL / keys
*.pem

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.python-version
/env/
/venv/
/.venv/
/envs/
/ENV/
/env.bak/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.ipynb_checkpoints/

# Editor directories and files
.vscode/
.idea/

# Misc logs
*.log
